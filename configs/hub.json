{
  "schema_version": 1,
  "mqtt_broker": "tcp://localhost:1883",
  "mqtt_client_id": "lexa-hub",
  "mqtt_user": "",
  "mqtt_pass_file": "",
  "metrics_addr": "",
  "engine_interval_s": 15,
  "debug": false,
  "constraint_shadow": false,
  "constraint_modes": {
    "export": "off",
    "gen": "off",
    "import": "off",
    "economics": "off",
    "battery_safety": "off"
  },
  "mode": "optimizer",
  "gateway": {
    "evse_policy": "scheduled",
    "evse_window": { "start_hh": 23, "end_hh": 7 },
    "evse_full_a": 32.0
  },
  "planner": {
    "batt_capacity_kwh": 10.0,
    "batt_max_charge_kw": 5.0,
    "batt_max_discharge_kw": 5.0,
    "batt_efficiency": 0.96,
    "terminal_reserve_pct": 20.0,
    "ev_capacity_kwh": 60.0,
    "ev_max_charge_kw": 7.68,
    "ev_voltage_v": 240.0,
    "ev_target_soc_pct": 80.0,
    "ev_departure_hh": 7,
    "solar_peak_kw": 8.0,
    "soc_step_kwh": 0.5,
    "replan_interval_s": 900
  },
  "devices": [
    {
      "name": "inverter-0",
      "role": "inverter",
      "max_w": 10000,
      "plant": {
        "max_ramp_down_w_per_s": 500.0,
        "max_ramp_up_w_per_s": 166.6666666667,
        "control_latency_s": 3.0
      }
    },
    {
      "name": "battery-0",
      "role": "battery",
      "max_w": 5000,
      "plant": {
        "capacity_kwh": 10.0,
        "soc_taper_start_pct": 80.0,
        "converge_frac": 0.5,
        "control_latency_s": 3.0,
        "soc_step_pct_per_tick_override": 1.0
      }
    },
    {
      "name": "meter-0",
      "role": "meter",
      "max_w": 0,
      "plant": {
        "meter_lag_s": 5.0,
        "filter_alpha": 0.4
      }
    }
  ],
  "stations": [
    {
      "id": "cs-001",
      "max_current_a": 32.0,
      "plant": {
        "meter_lag_s": 10.0
      }
    }
  ],
  "journal": {
    "dir": "/var/lib/lexa/journal/hub",
    "max_bytes": 1048576,
    "max_files": 4
  },
  "snapshot": {
    "enabled": true,
    "path": "/var/lib/lexa/snapshot/hub.json",
    "max_age_s": 300
  },
  "retained_adoption_max_age_s": 300,
  "tariff_zone": ""
}
