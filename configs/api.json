{
  "mqtt_broker": "tcp://localhost:1883",
  "mqtt_client_id": "lexa-api",
  "mqtt_user": "",
  "mqtt_pass_file": "",
  "listen_addr": "127.0.0.1:9100",
  "stale_after_s": 30,
  "log_buffer_size": 256,
  "api_token_file": "",
  "bench": false,
  "tls": true,
  "mdns": true,
  "serial_file": "/etc/lexa/identity/serial",
  "cert_dir": "/var/lib/lexa/api",
  "site_cache": "/var/lib/lexa/site.json",
  "journal": { "dir": "/var/lib/lexa/journal/api" },
  "devices": [
    {"name": "inverter-0", "role": "inverter", "max_w": 5000},
    {"name": "battery-0",  "role": "battery",  "max_w": 5000},
    {"name": "meter-0",    "role": "meter",    "max_w": 0}
  ],
  "schema_version": 1
}
